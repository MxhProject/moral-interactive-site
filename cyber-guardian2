<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover" />
<title>🛡️ 善意小英雄 · 拒绝网络霸凌</title>
<style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html,body { width:100%; height:100%; overflow:hidden; background:#1a1a2e; font-family:'Microsoft YaHei',sans-serif; touch-action:none; -webkit-user-select:none; user-select:none; }
    canvas { display:block; width:100%; height:100%; cursor:pointer; }
    .music-btn {
        position: fixed;
        top: 15px;
        right: 15px;
        z-index: 100;
        background: rgba(0,0,0,0.45);
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        width: 44px;
        height: 44px;
        font-size: 24px;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        user-select: none;
        -webkit-tap-highlight-color: transparent;
    }
</style>
</head>
<body>
<canvas id="gameCanvas"></canvas>
<div class="music-btn" id="musicBtn" title="音乐开关">🎵</div>

<script>
(function(){
    "use strict";
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const musicBtn = document.getElementById('musicBtn');

    // ==================== 背景音乐 ====================
    const bgMusic = new Audio('https://jackmum2025.github.io/forMiao/gagaga.mp3');
    bgMusic.loop = true;
    bgMusic.volume = 0.45;
    let musicPlaying = false;

    function updateMusicButton() {
        musicBtn.textContent = musicPlaying ? '🎵' : '🔇';
    }

    function playMusic() {
        if (!musicPlaying) {
            bgMusic.play().then(() => {
                musicPlaying = true;
                updateMusicButton();
            }).catch(e => {
                console.log('音乐播放需要用户手势');
                musicPlaying = false;
                updateMusicButton();
            });
        }
    }

    function pauseMusic() {
        if (musicPlaying) {
            bgMusic.pause();
            musicPlaying = false;
            updateMusicButton();
        }
    }

    function toggleMusic() {
        if (musicPlaying) {
            pauseMusic();
        } else {
            playMusic();
        }
    }

    musicBtn.addEventListener('click', toggleMusic);
    musicBtn.addEventListener('touchend', (e) => {
        e.preventDefault();
        toggleMusic();
    });

    // ==================== 图片配置 ====================
    const IMAGES = {
        playerRun: 'https://s1.aigei.com/prevfiles/0e5e962ab0a04e688cda449fc78ab65a.gif?e=2051020800&token=P7S2Xpzfz11vAkASLTkfHN7Fw-oOZBecqeJaxypL:Q84W9r3_doiMxSp7RMkEdcv44qE=',
        playerJump: '', playerSlide: '', obstacleBg: '', coinBg: '', cityBg: '', skyBg: '',
    };

    const loadedImages = {};
    function preloadImages() {
        Object.values(IMAGES).filter(u=>u&&u.trim()).forEach(url=>{
            const img=new Image(); img.crossOrigin='anonymous';
            img.onload=()=>console.log('✅ 图片加载成功');
            img.onerror=()=>console.log('⚠️ 图片加载失败');
            img.src=url; loadedImages[url]=img;
        });
    }
    function getImage(k){ const u=IMAGES[k]; return u&&loadedImages[u]&&loadedImages[u].complete&&loadedImages[u].naturalWidth>0?loadedImages[u]:null; }

    // ==================== 词库 ====================
    const POSITIVE_WORDS = [
        "🌟 停止霸凌","💪 勇敢举报","❤️ 支持受害者","🤗 你不是一个人","✨ 拒绝沉默",
        "🌈 尊重差异","🎉 传播善意","🌸 温柔说话","🕊️ 和平上网","⭐ 相信正义",
        "🌻 换位思考","🦋 远离谣言","🎈 寻求老师帮助","💎 自尊自爱","🔥 不对骂",
        "🌺 网络文明","☀️ 真相会赢","🌙 关闭恶意私信","⚡ 保留证据","🍀 治愈心灵",
        "🎵 用爱化解","📚 学习尊重","🎨 创造美好","🤝 团结同学","💖 抵制网暴"
    ];
    const NEGATIVE_WORDS = [
        "💢 去死吧","👎 你好丑","😠 威胁你全家","💔 造谣污蔑","🌪️ 人肉搜索",
        "🔇 集体孤立","👊 键盘暴力","📛 骂你猪","🚫 滚出网络","⚡ 羞辱取乐",
        "💀 诅咒你","🔨 恶意P图","🌑 曝光隐私","🔥 煽动围攻","🗑️ 垃圾人",
        "📱 骚扰轰炸","🖥️ 刷屏辱骂","🎭 冒充身份","📸 偷拍威胁","🗣️ 网络暴力"
    ];

    // ==================== 全局变量 ====================
    let W,H,gameState='start',frame=0,score=0,kindness=0,bestScore=0,survivalTime=0;
    let lastCollectedWord='',collectBubbleTimer=0,comboCount=0,comboTimer=0;
    try{bestScore=parseInt(localStorage.getItem('kr_v12'))||0}catch(e){}

    let baseSpeed=5.5,currentSpeed=baseSpeed;
    const MAX_SPEED=20,LANES=[-1,0,1];
    let currentLane=0,targetLane=0;

    let roadCurve=0, roadCurveTarget=0;
    let isBoostActive=false, boostTimer=0;
    let screenShake=0;

    const player={
        width:55,height:85,y:0,vy:0,
        jumping:false,sliding:false,slideTimer:0,slideCooldown:0,
        animTimer:0,runBounce:0,runSquash:0,trailParticles:[],
    };

    let negativeWords=[],positiveWords=[],particles=[],floatingTexts=[],sparkles=[];
    let posTimer=0,negTimer=0;
    const POS_INTERVAL=28,NEG_INTERVAL=75;
    let cGY,cHY;

    // ==================== 辅助 ====================
    function resize(){
        W=window.innerWidth;H=window.innerHeight;
        canvas.width=W;canvas.height=H;
        cGY=H*0.86;cHY=H*0.3;genSparkles();
    }
    window.addEventListener('resize',resize);resize();
    function groundY(){return cGY}
    function horizonY(){return cHY}
    function getX(l,z){
        const curveOffset=roadCurve*z*W*0.25;
        return W/2+l*W*0.38*Math.pow(z,0.7)*1.4+curveOffset;
    }
    function getY(z){return cHY+(cGY-cHY)*Math.pow(z,0.85)}
    function getS(z){return 0.45+z*1.15}

    function resetGame(){
        score=0;kindness=0;survivalTime=0;currentSpeed=baseSpeed;frame=0;
        lastCollectedWord='';collectBubbleTimer=0;comboCount=0;comboTimer=0;
        roadCurve=0;roadCurveTarget=0;isBoostActive=false;boostTimer=0;
        screenShake=0;
        currentLane=0;targetLane=0;
        player.y=groundY()-player.height;player.vy=0;
        player.jumping=false;player.sliding=false;player.slideTimer=0;player.slideCooldown=0;
        player.animTimer=0;player.runBounce=0;player.runSquash=0;player.trailParticles=[];
        negativeWords=[];positiveWords=[];particles=[];floatingTexts=[];
        posTimer=0;negTimer=0;genSparkles();
    }
    function genSparkles(){
        sparkles=[];
        const count=Math.min(35, Math.floor(W*H/22000));
        for(let i=0;i<count;i++)sparkles.push({
            x:Math.random()*W,y:Math.random()*cHY*1.5,size:.5+Math.random()*2,
            twinkle:Math.random()*Math.PI*2,speed:.03+Math.random()*.04,
            color:['#FFD700','#FFB6C1','#87CEEB','#98FB98','#DDA0DD'][Math.floor(Math.random()*5)]
        });
    }
    function startGame(){
        resetGame();
        gameState='playing';
        playMusic();
    }
    function gameOver(){
        if(gameState!=='playing')return;
        gameState='gameover';
        pauseMusic();
        score=Math.floor(survivalTime*10)+kindness*50;
        if(score>bestScore){bestScore=score;try{localStorage.setItem('kr_v12',bestScore)}catch(e){}}
        const px=getX(currentLane,0.9);
        for(let i=0;i<20;i++)particles.push({
            x:px+(Math.random()-.5)*100,y:player.y+(Math.random()-.5)*100,
            vx:(Math.random()-.5)*6,vy:-Math.random()*8-2,size:4+Math.random()*8,
            color:i%2?'#FF6B9D':'#FFD700',life:35+Math.random()*30,decay:.96,type:i%2?'heart':'star'
        });
    }

    // ==================== 游戏逻辑 ====================
    function update(){
        if(gameState!=='playing')return;
        frame++;

        if(frame%200===0) roadCurveTarget=(Math.random()-.5)*2;
        roadCurve+=(roadCurveTarget-roadCurve)*0.008;

        if(screenShake>0)screenShake*=0.85;
        if(screenShake<0.1)screenShake=0;

        if(isBoostActive){
            boostTimer--;
            currentSpeed=Math.min(MAX_SPEED+2,currentSpeed);
            if(boostTimer<=0){isBoostActive=false;currentSpeed=Math.min(currentSpeed,MAX_SPEED);}
        }

        if(comboTimer>0){comboTimer--;if(comboTimer<=0)comboCount=0;}

        player.animTimer+=0.15;
        player.runBounce=Math.abs(Math.sin(player.animTimer))*8;
        player.runSquash=Math.sin(player.animTimer)*0.08;

        // 尾迹生成降低频率
        if(frame%5===0&&!player.jumping){
            const px=getX(currentLane,0.92);
            player.trailParticles.push({x:px+(Math.random()-.5)*20,y:player.y+player.height-10,size:2+Math.random()*3,life:12,alpha:.5});
        }
        for(let i=player.trailParticles.length-1;i>=0;i--){
            player.trailParticles[i].life--;player.trailParticles[i].y+=2;
            player.trailParticles[i].alpha*=.9;
            if(player.trailParticles[i].life<=0)player.trailParticles.splice(i,1);
        }

        if(frame%6===0)survivalTime+=0.1;
        score=Math.floor(survivalTime*10)+kindness*50;
        if(collectBubbleTimer>0)collectBubbleTimer--;
        if(player.slideCooldown>0)player.slideCooldown--;
        if(frame%150===0&&currentSpeed<MAX_SPEED&&!isBoostActive)currentSpeed=Math.min(currentSpeed+.4,MAX_SPEED);

        currentLane+=(targetLane-currentLane)*0.25;
        if(Math.abs(currentLane-targetLane)<.01)currentLane=targetLane;

        player.vy+=0.8;player.y+=player.vy;
        const floorY=groundY()-(player.sliding?35:player.height);
        if(player.y>=floorY){
            if(player.jumping) checkStomp();
            player.y=floorY;player.vy=0;player.jumping=false;
        }
        if(player.sliding){player.slideTimer--;if(player.slideTimer<=0)player.sliding=false;}

        posTimer--;
        if(posTimer<=0){
            spawnPositive();if(Math.random()<.5)spawnPositive();if(Math.random()<.25)spawnPositive();
            posTimer=Math.max(18,Math.floor(POS_INTERVAL-currentSpeed*.25));
        }
        negTimer--;
        if(negTimer<=0){
            spawnNegative();
            if(currentSpeed>16&&Math.random()<.35)spawnNegative();
            negTimer=Math.max(50,Math.floor(NEG_INTERVAL-currentSpeed*.35));
        }

        for(let i=negativeWords.length-1;i>=0;i--){
            const w=negativeWords[i];
            w.z+=0.008+currentSpeed*0.001;
            if(w.z>1.3){negativeWords.splice(i,1);continue;}
            if(w.z>0.65&&w.z<1.05){
                if(checkCollision(w)){gameOver();return;}
            }
        }

        for(let i=positiveWords.length-1;i>=0;i--){
            const w=positiveWords[i];
            w.z+=0.01+currentSpeed*0.0012;
            if(w.z>1.25){positiveWords.splice(i,1);continue;}
            if(w.z>0.68&&w.z<1.0){
                if(checkCollection(w)){
                    kindness++;comboCount++;comboTimer=90;
                    lastCollectedWord=w.text;collectBubbleTimer=90;
                    const bonus=comboCount>=10?150:comboCount>=5?100:50;
                    const px=getX(w.lane,w.z),py=getY(w.z)-20;
                    // 减少粒子数量
                    for(let j=0;j<5+comboCount/2;j++)particles.push({
                        x:px,y:py,vx:(Math.random()-.5)*7,vy:(Math.random()-.8)*6-4,
                        size:3+Math.random()*5,color:j%3?'#FFD700':'#FF6B9D',
                        life:25,decay:.93,type:'star'
                    });
                    floatingTexts.push({x:px,y:py,text:'+'+bonus,color:'#FFD700',life:35,maxLife:35,alpha:1});

                    if(kindness>0&&kindness%50===0){
                        isBoostActive=true;boostTimer=150;screenShake=6;
                        for(let j=0;j<20;j++)particles.push({
                            x:getX(currentLane,0.9),y:player.y+player.height/2,
                            vx:(Math.random()-.5)*12,vy:(Math.random()-.8)*10-5,
                            size:4+Math.random()*8,color:'#00FFFF',life:35,decay:.95,type:'star'
                        });
                    }
                    positiveWords.splice(i,1);
                }
            }
        }

        // 更新粒子时清理远处粒子
        for(let i=particles.length-1;i>=0;i--){
            const p=particles[i];p.x+=p.vx;p.y+=p.vy;p.vy+=0.12;p.vx*=.98;
            p.life--;p.size*=p.decay||.97;
            if(p.life<=0||p.y>H+50)particles.splice(i,1);
        }
        for(let i=floatingTexts.length-1;i>=0;i--){
            const ft=floatingTexts[i];ft.y-=2.5;ft.life--;ft.alpha=ft.life/ft.maxLife;
            if(ft.life<=0)floatingTexts.splice(i,1);
        }
        for(let s of sparkles)s.twinkle+=s.speed;
    }

    function spawnPositive(){
        const count=1+(Math.random()>.5?1:0);
        const lanes=[...LANES].sort(()=>Math.random()-.5);
        for(let i=0;i<count;i++)positiveWords.push({
            lane:lanes[i],z:.04+i*.04,
            text:POSITIVE_WORDS[Math.floor(Math.random()*POSITIVE_WORDS.length)],
            floatOffset:0,glowPulse:1
        });
    }
    function spawnNegative(){
        negativeWords.push({
            lane:LANES[Math.floor(Math.random()*3)],z:.04,
            text:NEGATIVE_WORDS[Math.floor(Math.random()*NEGATIVE_WORDS.length)],
            width:0.12, height:0.08
        });
    }

    function checkStomp(){
        const px=getX(currentLane,0.92);
        for(let i=negativeWords.length-1;i>=0;i--){
            const w=negativeWords[i];
            if(w.z<0.8||w.z>1.05)continue;
            const ox=getX(w.lane,w.z),oy=getY(w.z);
            const s=getS(w.z),ww=W*w.width*s*.7,wh=H*w.height*s*.7;
            if(Math.abs(px-ox)<(player.width*.4+ww)/2&&Math.abs(player.y-oy)<wh){
                negativeWords.splice(i,1);
                score+=100;screenShake=6;
                for(let j=0;j<15;j++)particles.push({
                    x:ox,y:oy-wh/2,vx:(Math.random()-.5)*10,vy:-Math.random()*8-2,
                    size:3+Math.random()*6,color:'#FF6B6B',life:20,decay:.94,type:'star'
                });
                floatingTexts.push({x:ox,y:oy-wh/2,text:'💥踩碎!+100',color:'#FF6B6B',life:40,maxLife:40,alpha:1});
                break;
            }
        }
    }

    function checkCollision(obs){
        const px=getX(currentLane,0.92);
        let pw,ph,py;
        if(player.sliding){
            pw=player.width*.5; ph=18; py=player.y+22;
        }else if(player.jumping){
            pw=player.width*.35; ph=player.height*.35; py=player.y+player.height*.15;
        }else{
            pw=player.width*.45; ph=player.height*.45; py=player.y+player.height*.18;
        }
        const s=getS(obs.z);
        const ow=W*obs.width*s*0.6;
        const oh=H*obs.height*s*0.6;
        const ox=getX(obs.lane,obs.z),oy=getY(obs.z)-oh;
        if(Math.abs(px-ox)>(pw+ow)/2)return false;
        if(py+ph<oy+oh*.15)return false;
        if(py>oy+oh)return false;
        return true;
    }

    function checkCollection(word){
        const px=getX(currentLane,0.92);
        let pw,ph,py;
        if(player.sliding){pw=player.width*.55;ph=18;py=player.y+22;}
        else{pw=player.width*.5;ph=player.height*.5;py=player.y+player.height*.15;}
        const s=getS(word.z),ww=W*.14*s,wh=38*s;
        const wx=getX(word.lane,word.z),wy=getY(word.z)-wh-10;
        return Math.abs(px-wx)<(pw+ww)/2&&Math.abs(py-wy)<(ph+wh)/2;
    }

    // ==================== 输入 ====================
    function moveLeft(){if(gameState==='start')startGame();if(gameState!=='playing')return;targetLane=Math.max(-1,targetLane-1)}
    function moveRight(){if(gameState==='start')startGame();if(gameState!=='playing')return;targetLane=Math.min(1,targetLane+1)}
    function jump(){
        if(gameState==='start')startGame();
        if(gameState!=='playing')return;
        if(!player.jumping&&!player.sliding){player.vy=-19;player.jumping=true;}
    }
    function slide(){
        if(gameState==='start')startGame();
        if(gameState!=='playing')return;
        if(!player.jumping&&!player.sliding&&player.slideCooldown<=0){
            player.sliding=true;player.slideTimer=25;player.slideCooldown=20;
        }
    }

    document.addEventListener('keydown',(e)=>{
        if(e.code==='ArrowLeft'||e.code==='KeyA'){e.preventDefault();moveLeft()}
        if(e.code==='ArrowRight'||e.code==='KeyD'){e.preventDefault();moveRight()}
        if(e.code==='ArrowUp'||e.code==='Space'||e.code==='KeyW'){e.preventDefault();jump()}
        if(e.code==='ArrowDown'||e.code==='KeyS'){e.preventDefault();slide()}
        if(e.code==='Enter'&&gameState!=='playing')startGame();
    });

    let ts={x:0,y:0};
    canvas.addEventListener('touchstart',(e)=>{
        e.preventDefault();
        ts.x=e.touches[0].clientX;ts.y=e.touches[0].clientY;
        if(gameState!=='playing')startGame();
    },{passive:false});
    canvas.addEventListener('touchmove',(e)=>e.preventDefault(),{passive:false});
    canvas.addEventListener('touchend',(e)=>{
        e.preventDefault();
        if(gameState!=='playing')return;
        const dx=e.changedTouches[0].clientX-ts.x,dy=e.changedTouches[0].clientY-ts.y;
        if(Math.abs(dx)>Math.abs(dy)){
            if(dx>25) moveRight();
            else if(dx<-25) moveLeft();
        }else{
            if(dy<-25) jump();
            else if(dy>25) slide();
        }
    });
    canvas.addEventListener('mousedown',()=>{if(gameState!=='playing')startGame()});
    canvas.addEventListener('contextmenu',(e)=>e.preventDefault());

    // ==================== 渲染 ====================
    function draw(){
        const shakeX=screenShake>0?(Math.random()-.5)*screenShake:0;
        const shakeY=screenShake>0?(Math.random()-.5)*screenShake:0;

        ctx.save();ctx.translate(shakeX,shakeY);
        ctx.clearRect(-10,-10,W+20,H+20);

        const skyGrad=ctx.createLinearGradient(0,0,0,cHY+50);
        skyGrad.addColorStop(0,'#1a1a3e');skyGrad.addColorStop(.4,'#2d2b55');
        skyGrad.addColorStop(.8,'#5b4a7a');skyGrad.addColorStop(1,'#8b7aa0');
        ctx.fillStyle=skyGrad;ctx.fillRect(0,0,W,cHY+40);

        for(let s of sparkles){
            ctx.globalAlpha=.2+Math.sin(s.twinkle)*.2;
            ctx.fillStyle=s.color;ctx.beginPath();ctx.arc(s.x,s.y,s.size,0,Math.PI*2);ctx.fill();
        }
        ctx.globalAlpha=1;

        drawCity();
        drawRoad();

        for(let t of player.trailParticles){
            ctx.globalAlpha=t.alpha;ctx.fillStyle='#FFD700';
            ctx.beginPath();ctx.arc(t.x,t.y,t.size,0,Math.PI*2);ctx.fill();
        }
        ctx.globalAlpha=1;

        const list=[...negativeWords.map(w=>({t:'n',z:w.z,d:w})),...positiveWords.map(w=>({t:'p',z:w.z,d:w}))].sort((a,b)=>a.z-b.z);
        for(let item of list){if(item.t==='n')drawNeg(item.d);else drawPos(item.d)}

        drawPlayer();
        drawParticles();
        drawFloating();
        drawBubble();
        drawUI();

        ctx.restore();

        if(gameState==='start')drawStart();
        else if(gameState==='gameover')drawOver();
    }

    function drawCity(){
        const hY=cHY,colors=['#FFB6C1','#FFDAB9','#B0E0E6','#DDA0DD','#98FB98','#FFE4B5'];
        for(let i=0;i<6;i++){
            const x=(i*140+frame*.12)%(W+200)-100,w=35+Math.sin(i)*8,h=42+(i%3)*16;
            ctx.fillStyle=colors[i%6];ctx.globalAlpha=.5;
            ctx.fillRect(x,hY-h+15,w,h);
            ctx.fillStyle='#E8A0B0';ctx.globalAlpha=.35;
            ctx.beginPath();ctx.moveTo(x-3,hY-h+15);ctx.lineTo(x+w/2,hY-h-5);ctx.lineTo(x+w+3,hY-h+15);ctx.fill();
        }
        ctx.globalAlpha=1;
    }

    function drawRoad(){
        const hY=cHY,gY=groundY();
        ctx.beginPath();
        ctx.moveTo(W*.22,hY);ctx.lineTo(W*.78,hY);
        ctx.lineTo(W*.96,gY);ctx.lineTo(W*.04,gY);
        ctx.closePath();
        const rg=ctx.createLinearGradient(0,hY,0,gY);
        rg.addColorStop(0,'#4A6FA5');rg.addColorStop(1,'#2C3E50');
        ctx.fillStyle=rg;ctx.fill();

        if(Math.abs(roadCurve)>.3){
            ctx.strokeStyle='rgba(255,150,50,0.4)';ctx.lineWidth=3;ctx.setLineDash([5,8]);
            for(let z=.25;z<.85;z+=.08){
                const x=getX(0,z),y=getY(z);
                ctx.beginPath();ctx.arc(x,y,6*getS(z),0,Math.PI*2);ctx.stroke();
            }
            ctx.setLineDash([]);
        }

        ctx.strokeStyle='#FECA57';ctx.lineWidth=2.5;
        for(let li=-.5;li<=.5;li+=1){
            for(let i=0;i<10;i++){
                const z1=i/10,z2=(i+.4)/10;
                const x1=getX(li,z1),x2=getX(li,z2),y1=getY(z1),y2=getY(z2);
                if(((i/10+frame*currentSpeed*.005)%1)<.5){
                    ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
                }
            }
        }
    }

    function drawNeg(w){
        const x=getX(w.lane,w.z),y=getY(w.z),s=getS(w.z);
        const ww=W*w.width*s,wh=H*w.height*s;
        ctx.fillStyle='#8B5B6B';
        ctx.beginPath();rR(x-ww/2,y-wh,ww,wh,5);ctx.fill();
        ctx.strokeStyle='#FF4444';ctx.lineWidth=1.5*s;ctx.setLineDash([3,3]);ctx.stroke();ctx.setLineDash([]);
        ctx.fillStyle='#FFF';ctx.font=`bold ${Math.floor(9*s)}px "Microsoft YaHei"`;
        ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(w.text,x,y-wh/2);
    }

    function drawPos(w){
        const x=getX(w.lane,w.z),y=getY(w.z)+Math.sin(frame*.1+w.z)*4,s=getS(w.z);
        const ww=W*.13*s,wh=34*s;
        const g=ctx.createLinearGradient(x-ww/2,y-wh-8,x+ww/2,y-8);
        g.addColorStop(0,'#FFF8DC');g.addColorStop(.5,'#FFD700');g.addColorStop(1,'#FFA500');
        ctx.fillStyle=g;
        ctx.beginPath();rR(x-ww/2,y-wh-8,ww,wh,10);ctx.fill();
        ctx.fillStyle='#4A3728';
        ctx.font=`bold ${Math.floor(9*s)}px "Microsoft YaHei"`;
        ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(w.text,x,y-wh/2-8);
    }

    function drawPlayer(){
        const px=getX(currentLane,0.92);
        const py=player.y+(player.jumping?0:player.runBounce);
        const pw=player.width,ph=player.sliding?40:player.height;

        ctx.save();ctx.translate(px,py);
        if(player.sliding)ctx.rotate(-.15);

        const sx=player.jumping?1-player.runSquash:1+player.runSquash;
        const sy=player.jumping?1+player.runSquash:1-player.runSquash;
        ctx.scale(sx,sy);

        ctx.fillStyle='rgba(0,0,0,.18)';
        ctx.beginPath();ctx.ellipse(0,ph-2,pw*.35,5,0,0,Math.PI*2);ctx.fill();

        const playerImg=getImage('playerRun');
        if(playerImg){
            const iW=playerImg.naturalWidth||playerImg.width,iH=playerImg.naturalHeight||playerImg.height;
            const scale=Math.min(pw/iW,ph/iH)*1.3;
            const wobble=Math.sin(player.animTimer*1.5)*3;
            if(isBoostActive){ctx.shadowColor='#FF4500';ctx.shadowBlur=15}
            ctx.drawImage(playerImg,-iW*scale/2+wobble,-iH*scale/2,iW*scale,iH*scale);
            ctx.shadowBlur=0;
        }else{
            drawPlayerFallback(pw,ph);
        }

        if(player.sliding){
            ctx.strokeStyle='rgba(255,255,255,.35)';ctx.lineWidth=2;
            for(let i=0;i<3;i++){
                const lx=-pw/2-5-i*8,ly=-ph/4+i*ph/4;
                ctx.beginPath();ctx.moveTo(lx,ly);ctx.lineTo(lx-12,ly);ctx.stroke();
            }
        }

        ctx.restore();
    }

    function drawPlayerFallback(pw,ph){
        const by=player.sliding?-ph/2+15:-ph/2;
        const bg=ctx.createLinearGradient(-pw/2,-ph/2,pw/2,ph/2);
        bg.addColorStop(0,'#5DADE2');bg.addColorStop(.5,'#3498DB');bg.addColorStop(1,'#2874A6');
        ctx.fillStyle=bg;ctx.beginPath();rR(-pw/2,by,pw,ph*.6,12);ctx.fill();
        const hY=by-ph*.28,hR=pw*.3;
        ctx.fillStyle='#FFE4C4';ctx.beginPath();ctx.arc(0,hY,hR,0,Math.PI*2);ctx.fill();
        ctx.fillStyle='#4A3728';ctx.beginPath();ctx.arc(0,hY-hR*.55,hR*1.05,.15,Math.PI-.15);ctx.fill();
        ctx.fillStyle='#FF6B6B';ctx.beginPath();ctx.arc(0,hY-hR*.3,hR*.65,.15,Math.PI-.15);ctx.arc(0,hY-hR*.18,hR*.6,Math.PI-.15,.15,true);ctx.fill();
    }

    function drawParticles(){
        for(let p of particles){
            ctx.globalAlpha=Math.min(1,p.life/25);ctx.fillStyle=p.color;
            if(p.type==='heart'){
                const s=p.size*.5;
                ctx.beginPath();ctx.moveTo(p.x,p.y+s*.3);
                ctx.bezierCurveTo(p.x,p.y-s*.5,p.x-s,p.y-s*.3,p.x-s,p.y+s*.2);
                ctx.bezierCurveTo(p.x-s,p.y+s*.8,p.x,p.y+s*1.2,p.x,p.y+s);
                ctx.bezierCurveTo(p.x,p.y+s*1.2,p.x+s,p.y+s*.8,p.x+s,p.y+s*.2);
                ctx.bezierCurveTo(p.x+s,p.y-s*.3,p.x,p.y-s*.5,p.x,p.y+s*.3);ctx.fill();
            }else{
                ctx.beginPath();
                for(let i=0;i<4;i++){
                    const a=i*Math.PI*.8-Math.PI/2,r=i%2?p.size*.2:p.size*.5;
                    i?ctx.lineTo(p.x+Math.cos(a)*r,p.y+Math.sin(a)*r):ctx.moveTo(p.x+Math.cos(a)*r,p.y+Math.sin(a)*r);
                }
                ctx.closePath();ctx.fill();
            }
        }
        ctx.globalAlpha=1;
    }

    function drawFloating(){
        for(let ft of floatingTexts){
            ctx.globalAlpha=ft.alpha;ctx.fillStyle=ft.color;
            ctx.font='bold 14px "Microsoft YaHei"';ctx.textAlign='center';
            ctx.fillText(ft.text,ft.x,ft.y);
        }
    }

    function drawBubble(){
        if(collectBubbleTimer<=0||!lastCollectedWord)return;
        const px=getX(currentLane,0.92),alpha=Math.min(1,collectBubbleTimer/35),fy=(90-collectBubbleTimer)*.7;
        ctx.save();ctx.globalAlpha=alpha;ctx.translate(px,player.y-70-fy);
        ctx.fillStyle='#FFF8DC';
        ctx.beginPath();rR(-68,-20,136,38,18);ctx.fill();
        ctx.fillStyle='#4A3728';
        ctx.font='bold 12px "Microsoft YaHei"';ctx.textAlign='center';ctx.textBaseline='middle';
        ctx.fillText(lastCollectedWord+' +'+(comboCount>=10?150:comboCount>=5?100:50),0,-1);
        ctx.restore();
    }

    function drawUI(){
        ctx.fillStyle='rgba(0,0,0,.45)';ctx.beginPath();rR(10,10,200,85,15);ctx.fill();
        ctx.fillStyle='#FFF';ctx.font='bold 22px "Microsoft YaHei"';ctx.textAlign='left';
        ctx.fillText('🏆 '+score,25,40);
        ctx.fillStyle='#FFD700';ctx.font='bold 16px "Microsoft YaHei"';
        ctx.fillText('💖 善意 × '+kindness,25,65);

        if(comboCount>=3){
            ctx.fillStyle='#FF6B6B';ctx.font='bold 18px "Microsoft YaHei"';
            ctx.fillText('🔥 '+comboCount+'连击!',25,88);
        }

        if(isBoostActive){
            ctx.fillStyle='#FF4500';ctx.font='bold 18px "Microsoft YaHei"';ctx.textAlign='center';
            ctx.fillText('⚡冲刺中!',W/2,35);
        }

        if(Math.abs(roadCurve)>.4){
            ctx.fillStyle='rgba(255,150,0,.4)';ctx.font='bold 15px "Microsoft YaHei"';ctx.textAlign='center';
            ctx.fillText(roadCurve>0?'↻ 右弯道':'↺ 左弯道',W/2,60);
        }

        ctx.fillStyle='rgba(0,0,0,.45)';ctx.beginPath();rR(W-140,10,130,45,15);ctx.fill();
        ctx.fillStyle='#FFF';ctx.font='bold 15px "Microsoft YaHei"';ctx.textAlign='center';
        ctx.fillText('⏱️ '+survivalTime.toFixed(1)+'s',W-75,38);

        const sp=(currentSpeed-baseSpeed)/(MAX_SPEED-baseSpeed);
        ctx.fillStyle='rgba(0,0,0,.35)';ctx.fillRect(16,H-24,140,8);
        const sg=ctx.createLinearGradient(16,0,156,0);
        sg.addColorStop(0,'#2ECC71');sg.addColorStop(.5,'#F1C40F');sg.addColorStop(1,'#E74C3C');
        ctx.fillStyle=sg;ctx.fillRect(16,H-24,140*Math.min(1,sp),8);
    }

    function drawStart(){
        ctx.fillStyle='rgba(0,0,0,.65)';ctx.fillRect(0,0,W,H);
        const tY=H*.18;
        ctx.fillStyle='rgba(255,255,255,.08)';ctx.beginPath();rR(W/2-160,tY-20,320,220,20);ctx.fill();
        ctx.strokeStyle='rgba(255,255,255,.25)';ctx.lineWidth=2;ctx.stroke();
        ctx.fillStyle='#FFD700';ctx.font='bold 34px "Microsoft YaHei"';ctx.textAlign='center';
        ctx.fillText('🛡️ 善意小英雄',W/2,tY+15);
        ctx.fillStyle='#FFF';ctx.font='15px "Microsoft YaHei"';
        ctx.fillText('收集对抗霸凌的勇敢话语',W/2,tY+48);
        ctx.fillStyle='#FFB6C1';ctx.font='bold 16px "Microsoft YaHei"';
        ctx.fillText('💖 善意×50 + ⏱️ 时长×10',W/2,tY+75);
        ctx.fillStyle='#87CEEB';ctx.font='14px "Microsoft YaHei"';
        ctx.fillText('🔥 连击加分 | ⚡ 50善意冲刺 | 💥 跳跃踩碎',W/2,tY+100);
        ctx.fillStyle='#FFF';ctx.font='14px "Microsoft YaHei"';
        ctx.fillText('← → 移动 | ↑ 跳跃 | ↓ 滑铲',W/2,H*.60);
        ctx.fillText('点击屏幕或按 Enter 开始',W/2,H*.66);
    }

    function drawOver(){
        ctx.fillStyle='rgba(0,0,0,.75)';ctx.fillRect(0,0,W,H);
        ctx.fillStyle='#FF6B9D';ctx.font='bold 36px "Microsoft YaHei"';ctx.textAlign='center';
        ctx.fillText('💪 继续加油！',W/2,H*.24);
        ctx.fillStyle='#FFF';ctx.font='22px "Microsoft YaHei"';
        ctx.fillText('总分: '+score,W/2,H*.34);
        ctx.fillStyle='#FFD700';ctx.font='18px "Microsoft YaHei"';
        ctx.fillText('💖 善意:'+kindness+' | ⏱️ '+survivalTime.toFixed(1)+'s',W/2,H*.42);
        if(score>=bestScore&&score>0){
            ctx.fillStyle='#2ECC71';ctx.font='bold 22px "Microsoft YaHei"';
            ctx.fillText('🎉 新纪录！最棒的小英雄！',W/2,H*.52);
        }
        ctx.fillStyle='#BDC3C7';ctx.font='16px "Microsoft YaHei"';
        ctx.fillText('点击屏幕重新挑战',W/2,H*.65);
    }

    function rR(x,y,w,h,r){
        if(w<2*r)r=w/2;if(h<2*r)r=h/2;
        ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);
        ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);
        ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);
        ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);
        ctx.quadraticCurveTo(x,y,x+r,y);
    }

    function gameLoop(){
        if(gameState==='playing')update();
        draw();
        requestAnimationFrame(gameLoop);
    }

    preloadImages();resetGame();gameLoop();
})();
</script>
